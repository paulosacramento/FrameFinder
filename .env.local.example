# MoneyDevKit credentials
# Get these from https://moneydevkit.com/dashboard or run: npx @moneydevkit/create
MDK_ACCESS_TOKEN=your_mdk_api_key_here
MDK_MNEMONIC=your_mdk_mnemonic_here

# Payout destination for withdrawing earnings from MoneyDevKit
# Set to a Lightning Address (name@domain), LNURL, or Bolt12 offer
# Examples: cashtag@cash.app | lno... (Phoenix Bolt12)
WITHDRAWAL_DESTINATION=yourname@walletdomain.com

# Google Gemini API key
# Get this from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
